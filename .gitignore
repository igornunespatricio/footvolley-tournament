.env
# Terraform state (contains secrets, resource IDs)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform provider binaries (large, regenerated by `terraform init`)
terraform-provider-*
LICENSE.txt

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json

# Terraform crash logs
crash.log
crash.*.log

# Generated SSH key pair (sensitive!)
infra/app-key.pem
*.pem

# Terraform plan output files
*.tfplan